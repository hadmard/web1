  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.0",
    "next": "^14.2.0",
    "pinyin-pro": "^3.28.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "undici": "^7.22.0"
