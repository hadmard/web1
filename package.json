    "generate:seo-news": "ts-node --transpile-only -r tsconfig-paths/register -P scripts/tsconfig.scripts.json scripts/generate-seo-news.ts",
    "generate:dual-line-seo": "ts-node --transpile-only -r tsconfig-paths/register -P scripts/tsconfig.scripts.json scripts/generate-dual-line-seo-content.ts",
    "check:article-links": "ts-node --transpile-only -r tsconfig-paths/register -P scripts/tsconfig.scripts.json scripts/check-article-links.ts",
    "fix:article-links": "ts-node --transpile-only -r tsconfig-paths/register -P scripts/tsconfig.scripts.json scripts/fix-article-links.ts",
    "rewrite:seo-article": "ts-node --transpile-only -r tsconfig-paths/register -P scripts/tsconfig.scripts.json scripts/rewrite-seo-article.ts",
    "audit:seo-article-quality": "ts-node --transpile-only -r tsconfig-paths/register -P scripts/tsconfig.scripts.json scripts/audit-seo-article-quality.ts",
    "import:news": "ts-node --transpile-only scripts/import-news-feed.ts",
    "migrate:legacy-news-batch": "ts-node --transpile-only -P scripts/tsconfig.scripts.json scripts/migrate-legacy-news-batch.ts",
    "news:corrupted:handle": "ts-node --transpile-only -P scripts/tsconfig.scripts.json scripts/handle-corrupted-news.ts",
