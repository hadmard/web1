generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Term {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  definition   String
  background   String?
  features     String?
  structure    String?
  significance String?
  version      String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@map("terms")
}

model Standard {
  id               String             @id @default(cuid())
  title            String
  code             String
  year             Int
  content          String?
  version          String?
  publisher        String?
  effectiveAt      DateTime?
  levelDescription String?
  versionHistory   String?
  feedbacks        StandardFeedback[]
  updatedAt        DateTime           @updatedAt
  createdAt        DateTime           @default(now())

  @@map("standards")
}

model Brand {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  enterpriseId     String?  @unique
  enterprise       Enterprise? @relation(fields: [enterpriseId], references: [id], onDelete: SetNull)
  logoUrl          String?
  tagline          String?
  region           String?
  area             String?
  positioning      String?
  materialSystem   String?
  productStructure String?
  priceRange       String?
  targetAudience   String?
  businessModel    String?
  contactUrl       String?
  certUrl          String?
  isRecommend      Boolean  @default(false)
  isBrandVisible   Boolean  @default(true)
  sortOrder        Int      @default(0)
  rankingWeight    Int      @default(0)
  displayTemplate  String?
  memberTypeSnapshot String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@index([isBrandVisible, isRecommend, sortOrder])
  @@index([region, area])
  @@map("brands")
}

model IndustryData {
  id          String   @id @default(cuid())
  title       String
  source      String?
  methodology String?
  content     String?
  year        Int?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("industry_data")
}

model Member {
  id                  String             @id @default(cuid())
  name                String?
  email               String             @unique
  recoveryEmail       String?
  role                String?
  membershipLevel     String?
  memberType          String             @default("personal") // enterprise_basic | personal | enterprise_advanced
  canPublishWithoutReview Boolean        @default(false)
  canManageMembers    Boolean            @default(false)
  canDeleteOwnContent Boolean            @default(false)
  canDeleteMemberContent Boolean         @default(false)
  canDeleteAllContent Boolean            @default(false)
  canEditOwnContent   Boolean            @default(false)
  canEditMemberContent Boolean           @default(false)
  canEditAllContent   Boolean            @default(false)
  memberTypeExpiresAt DateTime?
  autoDowngradedAt    DateTime?
  rankingWeight       Int                @default(0)
  passwordHash        String
  passwordPlaintext   String?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  passwordResetRequestedAt DateTime?
  failedLoginCount    Int                @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  enterprise          Enterprise?
  enterpriseVerifications EnterpriseVerification[] @relation("MemberEnterpriseVerification")
  articles            Article[]          @relation("MemberArticles")
  galleryImages       GalleryImage[]     @relation("MemberGalleryImages")
  reviewedArticles    Article[]          @relation("ArticleReviewer")
  reviewedGallery     GalleryImage[]     @relation("GalleryReviewer")
  standardFeedbacks   StandardFeedback[]
  submittedArticleChanges ArticleChangeRequest[] @relation("ArticleChangeSubmitter")
  reviewedArticleChanges  ArticleChangeRequest[] @relation("ArticleChangeReviewer")
  reviewedEnterpriseVerifications EnterpriseVerification[] @relation("EnterpriseVerificationReviewer")
  passwordRecoveryRequests PasswordRecoveryRequest[] @relation("PasswordRecoveryRequestMember")
  handledPasswordRecoveryRequests PasswordRecoveryRequest[] @relation("PasswordRecoveryRequestHandler")

  @@index([memberType])
  @@index([memberTypeExpiresAt])
  @@index([recoveryEmail])
  @@index([passwordResetTokenHash])
  @@map("members")
}

model PasswordRecoveryRequest {
  id                    String   @id @default(cuid())
  memberId              String?
  member                Member?  @relation("PasswordRecoveryRequestMember", fields: [memberId], references: [id], onDelete: SetNull)
  account               String
  status                String   @default("pending") // pending | processing | sent | resolved | rejected
  requestNote           String?
  contactInfo           String?
  recoveryEmailSnapshot String?
  adminNote             String?
  handledById           String?
  handledBy             Member?  @relation("PasswordRecoveryRequestHandler", fields: [handledById], references: [id], onDelete: SetNull)
  handledAt             DateTime?
  lastSentAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([memberId, status])
  @@index([status, createdAt])
  @@index([handledById])
  @@map("password_recovery_requests")
}

model Enterprise {
  id              String   @id @default(cuid())
  memberId        String   @unique
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  brand           Brand?
  ownedArticles   Article[] @relation("EnterpriseOwnedArticles")
  inquiries       EnterpriseInquiry[]
  companyName     String?
  companyShortName String?
  contactPerson   String?
  website         String?
  address         String?
  licenseCode     String?
  foundedAt       String?
  registeredCapital String?
  verificationStatus String @default("approved") // pending | approved | rejected
  verifiedAt      DateTime?
  intro           String?
  logoUrl         String?
  positioning     String?
  productSystem   String?
  craftLevel      String?
  region          String?
  area            String?
  certifications  String?
  awards          String?
  contactInfo     String?
  contactPhone    String?
  relatedStandards String?
  relatedTerms    String?
  relatedBrands   String?
  videoUrl        String?
  sourceVerificationId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("enterprises")
}

model EnterpriseInquiry {
  id            String     @id @default(cuid())
  enterpriseId  String
  enterprise    Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  visitorName   String
  phone         String
  city          String?
  wechat        String?
  company       String?
  demand        String
  sourcePage    String?
  status        String     @default("new") // new | contacted | closed
  adminNote     String?
  handledAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([enterpriseId, status])
  @@index([createdAt])
  @@index([status])
  @@map("enterprise_inquiries")
}

model EnterpriseVerification {
  id                String   @id @default(cuid())
  memberId          String
  member            Member   @relation("MemberEnterpriseVerification", fields: [memberId], references: [id], onDelete: Cascade)
  companyName       String
  companyShortName  String?
  accountName       String
  accountPassword   String
  contactPerson     String
  contactPhone      String
  contactEmail      String?
  logoUrl           String?
  licenseImageUrl   String
  licenseCode       String
  address           String
  foundedAt         String?
  registeredCapital String?
  website           String?
  intro             String?
  businessScope     String?
  productSystem     String?
  coreAdvantages    String?
  attachmentsJson   String?
  status            String   @default("pending") // pending | approved | rejected
  reviewNote        String?
  reviewedAt        DateTime?
  reviewedById      String?
  reviewedBy        Member?  @relation("EnterpriseVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  approvedEnterpriseId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([memberId, status])
  @@index([status])
  @@index([reviewedById])
  @@map("enterprise_verifications")
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model Category {
  id               String        @id @default(cuid())
  href             String        @unique
  title            String
  desc             String?
  definitionText   String?
  versionLabel     String?
  versionYear      Int?
  relatedTermSlugs String?
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  subcategories    SubCategory[]
  faqs             CategoryFaq[]

  @@map("categories")
}

model SubCategory {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  href       String
  label      String
  groupLabel String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("sub_categories")
}

model CategoryFaq {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  question   String
  answer     String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("category_faqs")
}

model BuyingFaq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sort      Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, sort])
  @@map("buying_faqs")
}

model Tag {
  id        String       @id @default(cuid())
  type      String
  slug      String
  label     String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  articles  ArticleTag[]

  @@unique([type, slug])
  @@map("tags")
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model Article {
  id                  String        @id @default(cuid())
  title               String
  slug                String        @unique
  sourceType          String        @default("manual") @map("source_type")
  source              String?
  generationBatchId   String?       @map("generation_batch_id")
  keywordSeed         String?       @map("keyword_seed")
  keywordIntent       String?       @map("keyword_intent")
  sourceUrl           String?
  contentHash         String?       @map("content_hash")
  displayAuthor       String?
  excerpt             String?
  content             String
  coverImage          String?
  subHref             String?
  categoryHref        String?
  publishedAt         DateTime?
  status              String        @default("draft") // draft | pending | approved | rejected
  reviewNote          String?
  reviewedAt          DateTime?
  reviewedById        String?
  reviewedBy          Member?       @relation("ArticleReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  authorMemberId      String?
  authorMember        Member?       @relation("MemberArticles", fields: [authorMemberId], references: [id], onDelete: SetNull)
  ownedEnterpriseId   String?
  ownedEnterprise     Enterprise?   @relation("EnterpriseOwnedArticles", fields: [ownedEnterpriseId], references: [id], onDelete: SetNull)
  conceptSummary      String?
  applicableScenarios String?
  faqJson             String?
  versionLabel        String?
  relatedTermSlugs    String?
  relatedStandardIds  String?
  relatedBrandIds     String?
  tagSlugs            String?
  keywords            String?
  manualKeywords      String?       @map("manual_keywords")
  recommendIds        String?       @map("recommend_ids")
  syncToMainSite      Boolean       @default(false)
  isPinned            Boolean       @default(false)
  viewCount           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  tags                ArticleTag[]
  changeRequests      ArticleChangeRequest[]
  keywordItems        NewsKeyword[]
  baiduPushJob        BaiduPushJob?

  @@index([status])
  @@index([status, viewCount])
  @@index([status, isPinned])
  @@index([keywords])
  @@index([manualKeywords])
  @@index([contentHash])
  @@index([sourceType])
  @@index([generationBatchId])
  @@index([keywordSeed])
  @@index([keywordIntent])
  @@index([authorMemberId])
  @@index([ownedEnterpriseId])
  @@map("articles")
}

model BaiduPushJob {
  id            String   @id @default(cuid())
  articleId     String   @unique @map("article_id")
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  url           String?
  status        String   @default("pending") // pending | success | failed | skipped
  source        String?
  lastError     String?  @map("last_error")
  lastResponse  String?  @map("last_response")
  attemptCount  Int      @default(0) @map("attempt_count")
  lastAttemptAt DateTime? @map("last_attempt_at")
  pushedAt      DateTime? @map("pushed_at")
  nextRetryAt   DateTime? @map("next_retry_at")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextRetryAt])
  @@index([pushedAt])
  @@map("baidu_push_jobs")
}

model IndustryWhitelist {
  id          String   @id @default(cuid())
  word        String   @unique
  category    String
  subCategory String?  @map("sub_category")
  weight      Int      @default(1)
  synonyms    String?
  status      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([weight])
  @@map("industry_whitelist")
}

model PendingBrand {
  id              String   @id @default(cuid())
  brandName       String   @unique @map("brand_name")
  firstNewsId     String?  @map("first_news_id")
  lastNewsId      String?  @map("last_news_id")
  occurrenceCount Int      @default(1) @map("occurrence_count")
  articleCount    Int      @default(1) @map("article_count")
  articleIds      String?  @map("article_ids")
  lastOccurrence  DateTime? @map("last_occurrence")
  sourceContext   String?  @map("source_context")
  ruleSource      String?  @map("rule_source")
  triggerReason   String?  @map("trigger_reason")
  confidence      Float?
  approvedSource  String?  @map("approved_source")
  autoApprovedAt  DateTime? @map("auto_approved_at")
  status          Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("pending_brands")
}

model NewsKeyword {
  id          String   @id @default(cuid())
  newsId      String   @map("news_id")
  keyword     String
  weightScore Decimal? @db.Decimal(10, 2) @map("weight_score")
  isManual    Boolean  @default(false) @map("is_manual")
  sortOrder   Int?     @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  article     Article  @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@index([newsId])
  @@index([keyword])
  @@map("news_keywords")
}

model ArticleChangeRequest {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  submitterId     String
  submitter       Member   @relation("ArticleChangeSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  status          String   @default("pending") // pending | approved | rejected
  reason          String?
  patchTitle      String?
  patchSlug       String?
  patchExcerpt    String?
  patchContent    String?
  patchCoverImage String?
  patchSubHref    String?
  patchCategoryHref String?
  patchTagSlugs   String?
  patchRelatedTermSlugs String?
  patchRelatedStandardIds String?
  patchRelatedBrandIds String?
  diffSummary     String?
  reviewNote      String?
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      Member?  @relation("ArticleChangeReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([articleId])
  @@index([submitterId])
  @@index([status])
  @@map("article_change_requests")
}

model Award {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  year        Int?
  description String?
  coverImage  String?
  linkUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("awards")
}

model GalleryImage {
  id             String        @id @default(cuid())
  title          String?
  imageUrl       String
  alt            String?
  category       String?
  sortOrder      Int           @default(0)
  status         String        @default("draft") // draft | pending | approved | rejected
  reviewNote     String?
  reviewedAt     DateTime?
  reviewedById   String?
  reviewedBy     Member?       @relation("GalleryReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  authorMemberId String?
  authorMember   Member?       @relation("MemberGalleryImages", fields: [authorMemberId], references: [id], onDelete: SetNull)
  tagSlugs       String?
  syncToMainSite Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([authorMemberId])
  @@map("gallery_images")
}

model UserQuestion {
  id          String    @id @default(cuid())
  question    String
  sourceType  String
  sourceId    String?
  sourceLabel String?
  sourceHref  String?
  answer      String?
  answeredAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("user_questions")
}

model StandardFeedback {
  id         String        @id @default(cuid())
  memberId   String
  member     Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  standardId String?
  standard   Standard?     @relation(fields: [standardId], references: [id], onDelete: SetNull)
  content    String
  status     String   @default("pending") // draft | pending | approved | rejected
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([memberId])
  @@index([standardId])
  @@index([status])
  @@map("standard_feedbacks")
}

model OperationLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  targetType String
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetType])
  @@map("operation_logs")
}
