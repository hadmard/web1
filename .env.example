DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/web1?schema=public"
JWT_SECRET="your-secret-at-least-32-chars"
VIEW_DEDUP_SALT="your-view-dedup-salt"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# SMTP 优先于 Resend。
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="noreply@cnzhengmu.com"
# SMTP_PASS 不是邮箱登录密码，而是邮箱后台生成的授权码 / 应用专用密码。
SMTP_PASS="邮箱授权码"
MAIL_FROM="整木网 <noreply@cnzhengmu.com>"

# 若未配置 SMTP，可回退使用 Resend。
RESEND_API_KEY="re_xxx"

ADMIN_ACCOUNT="yfcccc"
ADMIN_PASSWORD="admin"
ADMIN_NAME="admin"
NEXT_PUBLIC_MEMBER_CONTACT_EMAIL="member@your-domain.com"
NEXT_PUBLIC_BUSINESS_CONTACT_EMAIL="service@your-domain.com"
NEXT_PUBLIC_CONTACT_PHONE="400-123-4567"
BAIDU_PUSH_SITE="cnzhengmu.com"
BAIDU_PUSH_TOKEN="your-baidu-push-token"
# SEO auto generation cron master switch.
# Only "true" will actually generate SEO drafts.
# When unset or not "true", cron will still trigger but will skip generation.
# SEO_NEWS_AUTOGEN_ENABLED="true"

# Optional AI key
# GEMINI_API_KEY="AIza..."
